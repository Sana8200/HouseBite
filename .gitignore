# IDE
.idea/
.vscode/

# Frontend
# => regenerated by npm install, no need to track
node_modules/
# => build output generated by npm run build, never commit artifacts
dist/
dist-ssr/
*.local
# => contains supabase keys, must never be exposed in version control
web/.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Supabase
# => local branch state managed by supabase cli, machine-specific
supabase/.branches/
# => temporary files created by supabase cli, not part of the project
supabase/.temp/

# OS
.DS_Store

supabase/functions/.env