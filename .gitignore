# IDE
.idea/
.vscode/

# Frontend
web/node_modules/ # => regenerated by npm install, no need to track
web/dist/         # => build output generated by npm run build, never commit artifacts
web/.env          # => contains supabase keys, must never be exposed in version control
web/.env.local
web/.env.*.local

# Supabase
supabase/.branches/ # => local branch state managed by supabase cli, machine-specific
supabase/.temp/     # => temporary files created by supabase cli, not part of the project

# OS
.DS_Store
